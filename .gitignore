**/linux/flutter/generated_plugin_registrant.*
*.jks
*.keystore

# Python and script caches
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
.venv/
venv/
env/

# IDE, editor, and OS noise
.idea/
*.iml
