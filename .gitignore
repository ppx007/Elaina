._*
Thumbs.db

# Logs, temporary files, and caches
*.log
*.tmp
*.temp
*.bak
.tmp/
tmp/
temp/
.cache/
**/.cache/

# Trellis legacy runtime state
.trellis/.developer
.trellis/.current-task
.trellis/.runtime/
.trellis/.backup-*/
.trellis/worktrees/
.trellis/.template-hashes.json
.trellis/.cache/
